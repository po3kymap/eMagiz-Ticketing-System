<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence" version="3.0">
    <persistence-unit name="emagiz-pu">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>
        <class>com.emagiz.model.User</class> <properties>
        <property name="jakarta.persistence.jdbc.driver" value="org.postgresql.Driver" />
        <property name="jakarta.persistence.jdbc.url" value="jdbc:postgresql://localhost:5434/emagiz_ticketing" />
        <property name="jakarta.persistence.jdbc.user" value="emagiz4" />
        <property name="jakarta.persistence.jdbc.password" value="emagiz4pass" />

        <property name="hibernate.dialect" value="org.hibernate.dialect.PostgreSQLDialect" />
        <property name="hibernate.show_sql" value="true" />
        <property name="hibernate.hbm2ddl.auto" value="update" />
    </properties>
    </persistence-unit>
</persistence>